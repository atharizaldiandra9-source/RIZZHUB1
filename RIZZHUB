--// AUTO ATTACK
--// =======================================================

Tab:AddToggle({
	Name = "Auto Attack",
	Default = false,
	Callback = function(Value)
		Flags.AutoAttack = Value

		if Value then
			Disconnect("AutoAttack")
			Connections.AutoAttack = RunService.RenderStepped:Connect(function()
				local char = GetCharacter()
				if not char then return end

				local tool = char:FindFirstChildOfClass("Tool")
