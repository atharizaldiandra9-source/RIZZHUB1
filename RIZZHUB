UserInputService.InputBegan:Connect(function(input, gp)
	if gp then return end
	if input.KeyCode == ToggleKey then
		Flags.AutoAttack = not Flags.AutoAttack
		Notify("Auto Attack", Flags.AutoAttack and "Enabled" or "Disabled")
	end
end)

--// =======================================================
--// AUTO PARRY MECHANIC
--// =======================================================

local player = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local humanoidRootPart = character:WaitForChild("HumanoidRootPart")
local PARRY_RADIUS = 5 

RunService.RenderStepped:Connect(function()
	for _, otherPlayer in pairs(Players:GetPlayers()) do
		if otherPlayer ~= player and otherPlayer.Character then
			local killerRoot = otherPlayer.Character:FindFirstChild("HumanoidRootPart")
			
			if killerRoot and (killerRoot.Position - humanoidRootPart.Position).Magnitude < PARRY_RADIUS then
				if otherPlayer.Character:FindFirstChild("IsAttacking") then
					task.spawn(function()
						pcall(function()
							game.ReplicatedStorage.Events.ParryEvent:FireServer()
						end)
					end)
				end
			end
		end
	end
end)

