--// =======================================================
--// MINI RADAR
--// =======================================================

Tab:AddToggle({
	Name = "Mini Radar",
	Default = false,
	Callback = function(Value)
		Flags.Radar = Value

		if Value then
			local Radar = Instance.new("ScreenGui")
			Radar.Name = "RizzRadar"
			Radar.Parent = CoreGui

			local Frame = Instance.new("Frame")
			Frame.Size = UDim2.new(0,150,0,150)
			Frame.Position = UDim2.new(0,20,0,20)
			Frame.BackgroundTransparency = 0.3
			Frame.Parent = Radar

			Connections.Radar = RunService.Heartbeat:Connect(function()
				for _, child in pairs(Frame:GetChildren()) do
					if child.Name == "Dot" then
						child:Destroy()
					end
				end

				local myChar = GetCharacter()
				if not myChar then return end

				local myRoot = myChar:FindFirstChild("HumanoidRootPart")
				if not myRoot then return end

				for _, player in pairs(Players:GetPlayers()) do
					if player ~= LocalPlayer and player.Character then
						local root = player.Character:FindFirstChild("HumanoidRootPart")
						if root then
							local dist = root.Position - myRoot.Position
							local Dot = Instance.new("Frame")
							Dot.Name = "Dot"
							Dot.Size = UDim2.new(0,5,0,5)
							Dot.Position = UDim2.new(0.5, dist.X * 0.4, 0.5, dist.Z * 0.4)
							Dot.BackgroundColor3 = Color3.fromRGB(255,0,0)
							Dot.Parent = Frame
						end
					end
				end
			end)
		else
			Disconnect("Radar")
			local Radar = CoreGui:FindFirstChild("RizzRadar")
			if Radar then
				Radar:Destroy()
			end
		end
	end
})

