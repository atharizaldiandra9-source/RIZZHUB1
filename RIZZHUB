--// RIZZ HUB PRO - STABLE FINAL
local OrionLib = loadstring(game:HttpGet("https://raw.githubusercontent.com/jensonhirst/Orion/main/source"))()
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local Camera = workspace.CurrentCamera
local LocalPlayer = Players.LocalPlayer

local Settings = {
    Aimbot = false, Smooth = 10, TeamCheck = true, WallCheck = true,
    Aura = false, AuraRange = 10,
    ESP = false, FOV = false, FOVSize = 100
}

local FOVCircle = Drawing.new("Circle")
FOVCircle.Visible = false
FOVCircle.Thickness = 1
FOVCircle.Filled = false
FOVCircle.Radius = 100
FOVCircle.Color = Color3.fromRGB(255, 255, 255)

local Window = OrionLib:MakeWindow({Name = "RizzHub Pro", HidePremium = true, SaveConfig = false, Icon = "rbxassetid://13589886470"})
local CombatTab = Window:MakeTab({Name = "Combat", Icon = "rbxassetid://13589886470"})
local VisualTab = Window:MakeTab({Name = "Visuals", Icon = "rbxassetid://13589886470"})

--// SLIDERS & TOGGLES
CombatTab:AddToggle({Name = "Aimbot", Default = false, Callback = function(v) Settings.Aimbot = v end})
CombatTab:AddSlider({Name = "Smoothness", Min = 1, Max = 20, Default = 10, Callback = function(v) Settings.Smooth = v end})
CombatTab:AddToggle({Name = "Kill Aura", Default = false, Callback = function(v) Settings.Aura = v end})
CombatTab:AddSlider({Name = "Aura Range", Min = 5, Max = 20, Default = 10, Callback = function(v) Settings.AuraRange = v end})
CombatTab:AddToggle({Name = "Team Check", Default = true, Callback = function(v) Settings.TeamCheck = v end})
CombatTab:AddToggle({Name = "Wall Check", Default = true, Callback = function(v) Settings.WallCheck = v end})

VisualTab:AddToggle({Name = "Enable ESP", Default = false, Callback = function(v) Settings.ESP = v end})
VisualTab:AddToggle({Name = "Show FOV Circle", Default = false, Callback = function(v) Settings.FOV = v; FOVCircle.Visible = v end})
VisualTab:AddSlider({Name = "FOV Size", Min = 50, Max = 500, Default = 100, Callback = function(v) Settings.FOVSize = v; FOVCircle.Radius = v end})

--// ESP LOGIC
RunService.RenderStepped:Connect(function()
    FOVCircle.Position = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
    
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local h = p.Character:FindFirstChild("RizzHighlight")
            if Settings.ESP then
                if not h then h = Instance.new("Highlight", p.Character); h.Name = "RizzHighlight" end
                h.FillColor = (p.TeamColor == LocalPlayer.TeamColor) and Color3.fromRGB(0, 0, 255) or Color3.fromRGB(255, 0, 0)
            elseif h then h:Destroy() end
        end
    end

    --// AURA & AIMBOT LOGIC
    local closestTarget = nil
    local shortestDist = Settings.FOVSize

    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character:FindFirstChild("Head") then
            if Settings.TeamCheck and p.TeamColor == LocalPlayer.TeamColor then continue end
            
            local rootPos = p.Character.HumanoidRootPart.Position
            local headPos = p.Character.Head.Position
            local distFromLocal = (rootPos - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude
            
            -- Aura
            if Settings.Aura and distFromLocal <= Settings.AuraRange then
                local tool = LocalPlayer.Character:FindFirstChildOfClass("Tool")
                if tool then tool:Activate() end
            end
            
            -- Aimbot Target Search
            local pos, onScreen = Camera:WorldToViewportPoint(headPos)
            local mouseDist = (Vector2.new(pos.X, pos.Y) - Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)).Magnitude
            
            if onScreen and mouseDist <= Settings.FOVSize then
                if Settings.WallCheck then
                    local ray = Ray.new(Camera.CFrame.Position, headPos - Camera.CFrame.Position)
                    local hit = workspace:FindPartOnRayWithIgnoreList(ray, {LocalPlayer.Character, Camera})
                    if not hit or not hit:IsDescendantOf(p.Character) then continue end
                end
                if mouseDist < shortestDist then
                    closestTarget = headPos
                    shortestDist = mouseDist
                end
            end
        end
    end

    if Settings.Aimbot and UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) and closestTarget then
        local targetPos = Camera:WorldToScreenPoint(closestTarget)
        local mousePos = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
        local move = (Vector2.new(targetPos.X, targetPos.Y) - mousePos) / Settings.Smooth
        mousemoverel(move.X, move.Y)
    end
end)

OrionLib:Init()
