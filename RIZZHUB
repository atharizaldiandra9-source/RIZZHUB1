local OrionLib = loadstring(game:HttpGet("https://raw.githubusercontent.com/jensonhirst/Orion/main/source"))()

--// VARIABLES
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local LocalPlayer = Players.LocalPlayer
local Flags = {SurvivorColor = Color3.fromRGB(0, 255, 0), KillerColor = Color3.fromRGB(255, 0, 0)}

--// UI SETUP
local Window = OrionLib:MakeWindow({Name = "RizzHub", HidePremium = false, SaveConfig = true, IntroEnabled = true})

--// TAB 1: GENERATORS
local GenTab = Window:MakeTab({Name = "Generators", Icon = "rbxassetid://4483345998"})
GenTab:AddSection({Name = "Generator Tools"})

--// TAB 2: SURVIVOR
local SurvTab = Window:MakeTab({Name = "Survivor", Icon = "rbxassetid://4483345998"})
SurvTab:AddSection({Name = "Survivor Abilities"})

--// TAB 3: KILLER
local KillTab = Window:MakeTab({Name = "Killer", Icon = "rbxassetid://4483345998"})
KillTab:AddSection({Name = "Killer Abilities"})

--// TAB 4: VISUAL
local VisualTab = Window:MakeTab({Name = "Visual", Icon = "rbxassetid://4483345998"})
VisualTab:AddSection({Name = "ESP Aura Settings"})

VisualTab:AddColorpicker({
	Name = "Survivor Aura",
	Default = Color3.fromRGB(0, 255, 0),
	Callback = function(Value) Flags.SurvivorColor = Value end
})

VisualTab:AddColorpicker({
	Name = "Killer Aura",
	Default = Color3.fromRGB(255, 0, 0),
	Callback = function(Value) Flags.KillerColor = Value end
})

--// TAB 5: PLAYER
local PlayerTab = Window:MakeTab({Name = "Player", Icon = "rbxassetid://4483345998"})
PlayerTab:AddSection({Name = "Movement"})

--// CLEANUP: Pastikan tidak ada fungsi yang bentrok
print("RizzHub Clean Version Re-Initialized")
