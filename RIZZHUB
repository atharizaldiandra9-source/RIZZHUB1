--// =======================================================
--// RIZZ HUB - ESP, AURA, AIMBOT & FOV
--// =======================================================

local OrionLib = loadstring(game:HttpGet("https://raw.githubusercontent.com/jensonhirst/Orion/main/source"))()
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local Camera = workspace.CurrentCamera
local LocalPlayer = Players.LocalPlayer

local Window = OrionLib:MakeWindow({Name = "RizzHub | Pro", HidePremium = true, SaveConfig = true, ConfigFolder = "RizzHub"})
local Tab = Window:MakeTab({Name = "Combat & Visual", Icon = "rbxassetid://122214542643927"})

local Flags = {ESP = false, Aimbot = false, FOV = false, Aura = false, Range = 10, FOVSize = 100}

--// FOV CIRCLE
local FOVCircle = Drawing.new("Circle")
FOVCircle.Visible = false
FOVCircle.Thickness = 1
FOVCircle.Radius = 100
FOVCircle.Color = Color3.fromRGB(255, 255, 255)
FOVCircle.Position = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)

--// WALL CHECK & TEAM CHECK
local function IsVisible(target)
    local origin = Camera.CFrame.Position
    local targetPos = target:FindFirstChild("Head") and target.Head.Position or target:FindFirstChild("HumanoidRootPart").Position
    local ray = Ray.new(origin, targetPos - origin)
    local hit = workspace:FindPartOnRayWithIgnoreList(ray, {LocalPlayer.Character, Camera})
    return hit and hit:IsDescendantOf(target)
end

--// AIMBOT LOGIC
local function GetClosestPlayer()
    local closestPlayer = nil
    local shortestDistance = Flags.FOVSize

    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.TeamColor ~= LocalPlayer.TeamColor and p.Character and p.Character:FindFirstChild("Head") then
            local pos, onScreen = Camera:WorldToViewportPoint(p.Character.Head.Position)
            if onScreen then
                local dist = (Vector2.new(pos.X, pos.Y) - Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)).Magnitude
                if dist < shortestDistance and IsVisible(p.Character) then
                    closestPlayer = p.Character.Head
                    shortestDistance = dist
                end
            end
        end
    end
    return closestPlayer
end

--// UI ELEMENTS
Tab:AddToggle({Name = "Aimbot (Team/Wall Check)", Default = false, Callback = function(v) Flags.Aimbot = v end})
Tab:AddToggle({Name = "Show FOV Circle", Default = false, Callback = function(v) Flags.FOV = v; FOVCircle.Visible = v end})
Tab:AddSlider({Name = "FOV Size", Min = 50, Max = 500, Default = 100, Callback = function(v) Flags.FOVSize = v; FOVCircle.Radius = v end})

--// UPDATE LOOP
RunService.RenderStepped:Connect(function()
    FOVCircle.Position = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
    
    if Flags.Aimbot and UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then
        local target = GetClosestPlayer()
        if target then
            Camera.CFrame = CFrame.new(Camera.CFrame.Position, target.Position)
        end
    end
end)

OrionLib:Init()
