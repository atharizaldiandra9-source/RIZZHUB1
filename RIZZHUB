--// =======================================================
--// AURA ESP & REALTIME GENERATOR TRACKER
--// =======================================================

local function CreatePlayerAura(target, color)
	if target:FindFirstChild("RizzESP") then 
		target.RizzESP.FillColor = color
		target.RizzESP.OutlineColor = color
		return 
	end

	local Highlight = Instance.new("Highlight")
	Highlight.Name = "RizzESP"
	Highlight.FillColor = color
	Highlight.OutlineColor = color
	Highlight.FillTransparency = 0.4
	Highlight.OutlineTransparency = 0.1
	Highlight.Parent = target
end

local function CreateGeneratorESP(gen)
	if gen:FindFirstChild("GenESP") then return end

	-- Aura untuk Generator (Biru)
	local Highlight = Instance.new("Highlight")
	Highlight.Name = "GenESP"
	Highlight.FillColor = Color3.fromRGB(0, 180, 255)
	Highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
	Highlight.FillTransparency = 0.6
	Highlight.Parent = gen

	-- Text Persentase Realtime
	local Billboard = Instance.new("BillboardGui")
	Billboard.Name = "GenProgressUI"
	Billboard.Size = UDim2.new(0, 100, 0, 40)
	Billboard.AlwaysOnTop = true
	Billboard.StudsOffset = Vector3.new(0, 4, 0)
	Billboard.Parent = gen

	local TextLabel = Instance.new("TextLabel")
	TextLabel.Size = UDim2.new(1, 0, 1, 0)
	TextLabel.BackgroundTransparency = 1
	TextLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
	TextLabel.TextStrokeTransparency = 0
	TextLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
	TextLabel.Font = Enum.Font.SourceSansBold
	TextLabel.TextSize = 16
	TextLabel.Text = "Gen: 0%"
	TextLabel.Parent = Billboard

	-- Loop update progres realtime
	task.spawn(function()
		while Flags.ESP and gen:IsDescendantOf(workspace) do
			local progressVal = gen:FindFirstChild("Progress") or gen:FindFirstChild("ProgressValue")
			if progressVal then
				local percentage = math.floor(progressVal.Value)
				TextLabel.Text = "Gen: " .. tostring(percentage) .. "%"
				
				-- Ubah warna teks dinamis sesuai progres
				if percentage >= 100 then
					TextLabel.TextColor3 = Color3.fromRGB(0, 255, 0)
					TextLabel.Text = "COMPLETED"
				elseif percentage > 50 then
					TextLabel.TextColor3 = Color3.fromRGB(255, 200, 0)
				else
					TextLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
				end
			end
			task.wait(0.2)
		end
	end)
end

local function ClearAllESP()
	for _, v in pairs(workspace:GetDescendants()) do
		if v.Name == "RizzESP" or v.Name == "GenESP" or v.Name == "GenProgressUI" then
			v:Destroy()
		end
	end
end

Tab:AddToggle({
	Name = "Visual ESP (Aura & Gen %)",
	Default = false,
	Callback = function(Value)
		Flags.ESP = Value

		if Value then
			Disconnect("ESP_Loop")
			Connections.ESP_Loop = RunService.Heartbeat:Connect(function()
				if not Flags.ESP then return end
				
				-- Player ESP Aura (No Text)
				for _, player in pairs(Players:GetPlayers()) do
					if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
						local char = player.Character
						local isKiller = player:GetAttribute("Role") == "Killer" or char:FindFirstChild("IsAttacking")
						local hasDagger = char:FindFirstChildOfClass("Tool") and (string.find(char:FindFirstChildOfClass("Tool").Name:lower(), "dagger") or string.find(char:FindFirstChildOfClass("Tool").Name:lower(), "knife"))

						if isKiller or hasDagger then
							CreatePlayerAura(char, Color3.fromRGB(255, 0, 0)) -- Merah jika berbahaya / bawa dagger
						else
							CreatePlayerAura(char, Color3.fromRGB(0, 255, 0)) -- Hijau jika kawan/survivor
						end
					end
				end

				-- Generator Tracking
				for _, obj in pairs(workspace:GetDescendants()) do
					if string.find(obj.Name:lower(), "generator") and obj:IsA("BasePart") then
						CreateGeneratorESP(obj)
					end
				end
			end)
		else
			ClearAllESP()
			Disconnect("ESP_Loop")
		end
	end
})

